# ─────────────────────────────────────────────────────────────────────────────
# @rg/desktop environment (read by the MAIN process — src/main/config.ts)
#
# Copy to `.env` for local dev. The renderer never reads these directly.
# Marketplace credentials are NEVER stored here — they live in the OS keystore
# (DPAPI / Windows Credential Manager) at runtime. See ARCHITECTURE.md §5.
# Full reference: docs/ENVIRONMENT.md
# ─────────────────────────────────────────────────────────────────────────────

# Backend REST base (WITHOUT the /api/v1 suffix — the client appends it).
RG_BACKEND_URL=http://localhost:4000

# Supabase project URL + public anon key (CSP connect-src + Realtime).
RG_SUPABASE_URL=https://PROJECT.supabase.co
RG_SUPABASE_ANON_KEY=eyJ...

# Salt mixed into the device fingerprint hash (not a secret per se).
RG_DEVICE_SALT=return-genie-device-v1

# Polling + update intervals (ms).
RG_SYNC_POLL_MS=4000
RG_UPDATE_CHECK_MS=21600000

# ── Automation tuning (optional) ─────────────────────────────────────────────
# RG_PACE=1                      # human-pause multiplier
# MYNTRA_PROXY_URL=              # route Myntra traffic via a proxy if needed
# MYNTRA_LOGIN_TIMEOUT_MS=90000
# MYNTRA_REPORT_TIMEOUT_MS=900000
