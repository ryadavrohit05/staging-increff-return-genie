# ─────────────────────────────────────────────────────────────────────────────
# @rg/admin environment (Vite — only VITE_* vars are exposed to the browser)
#
# Copy to `.env.local` for local dev. In production these are set as Vercel
# Environment Variables. NONE of these are secrets: the anon key is public by
# design (RLS + backend SUPERADMIN checks enforce access); never put the Supabase
# service-role key here.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash). Local: http://localhost:4000
VITE_BACKEND_URL=http://localhost:4000

# Supabase project URL + public anon key (used only for SUPERADMIN login).
VITE_SUPABASE_URL=https://PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
