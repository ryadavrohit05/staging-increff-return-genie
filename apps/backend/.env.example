# ─────────────────────────────────────────────────────────────────────────────
# @rg/backend environment
#
# Copy to `.env` and fill in. NEVER commit a real `.env`.
# The external-API and Supabase service-role credentials live ONLY here and are
# never returned to clients, never logged (pino redaction).
# ─────────────────────────────────────────────────────────────────────────────

# HTTP
PORT=4000

# CORS allowlist (comma-separated origins). The desktop app uses its own origin;
# the admin portal (Vercel) uses its deployed URL.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# Pooled connection (PgBouncer, port 6543) — used by the app at runtime.
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection (port 5432) — used by Prisma Migrate and pg-boss DDL.
DIRECT_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://PROJECT.supabase.co
# Public anon key — used to verify user JWTs and proxy the password grant.
SUPABASE_ANON_KEY=eyJ...
# Service-role key — bypasses RLS for trusted writes + Storage admin. SECRET.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# JWT signing secret (Project Settings → API → JWT Secret). Used to verify tokens
# locally without a network round-trip. SECRET.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters

# ── External upload API (Increff CIMS) — creds live ONLY here ────────────────
# Slug-driven. Adidas is the active tenant; any other client slots in by its
# slug alone (per-org override via PUT /admin/orgs/:id/external-api, which stores
# the password AES-256-GCM-encrypted in the DB).
#   host   = https://{client}.omni.increff.com
#   domain = {client}-oltp
#   user   = EXTERNAL_API_USERNAME (shared across clients)
# Auth is via custom headers: authUsername / authPassword / authDomainName.
EXTERNAL_API_CLIENT=adidasgcc
EXTERNAL_API_HOST_TEMPLATE=https://{client}.omni.increff.com
EXTERNAL_API_DOMAIN_TEMPLATE={client}-oltp
EXTERNAL_API_RETURN_ORDERS_PATH=/cims/import/returnOrders
EXTERNAL_API_USERNAME=adidasgcc-system.user
EXTERNAL_API_PASSWORD=changeme
# 32-byte secret used to encrypt per-org passwords at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
EXTERNAL_API_ENC_KEY=change-me-to-a-random-32-byte-base64-value

# ── CIMS import payload params (per the proven n8n "Format JSON Payload") ────
# Currently the Adidas tenant's values.
CIMS_OMS_LOCATION_ID=1100149519
CIMS_FULFILLMENT_LOCATION_CODE=8713-1
CIMS_CLIENT_ID=1100149303
CIMS_CHANNEL_ID=MYNTRAV4

# ── Webget dedup (query CIMS for orders that already exist before submitting) ─
WEBGET_URL=https://saas.increff.com/webget/in/api/app/sql/result
WEBGET_SCHEMA=cims
WEBGET_DB_ID=162
WEBGET_TABLE=cims_return_order_pojo
WEBGET_ID_COLUMN=channel_order_id
WEBGET_CHANNEL_COLUMN=channel_id
WEBGET_BATCH_SIZE=3000
# "Webget system user" custom-auth headers as a JSON object. Empty ⇒ dedup skipped.
# NOTE: Webget uses authOrgName (CIMS uses authDomainName).
WEBGET_AUTH_HEADERS={"authUsername":"<webget-user>","authPassword":"<webget-password>","authOrgName":"<org>"}

# ── n8n (optional, transitional) ─────────────────────────────────────────────
# If set, the processing pipeline posts the report to n8n instead of calling the
# external API directly. Leave empty to use the direct external API (default).
N8N_WEBHOOK_URL=

# ── Licensing / versioning ───────────────────────────────────────────────────
# Seconds a client may operate offline before hard-stopping (72h default).
OFFLINE_GRACE_SECONDS=259200
# Clients below this semver are forced to update.
MIN_SUPPORTED_VERSION=0.1.0

# ── Storage buckets ──────────────────────────────────────────────────────────
STORAGE_BUCKET_REPORTS=reports
STORAGE_BUCKET_RESULTS=results
STORAGE_BUCKET_SCREENSHOTS=screenshots
# Private bucket holding the desktop installer (gated, signed-URL download).
STORAGE_BUCKET_RELEASES=releases
