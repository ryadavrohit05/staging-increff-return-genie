{
  "name": "return-genie",
  "version": "0.1.0",
  "private": true,
  "description": "Return Genie — desktop SaaS automation platform (Electron + Playwright + Supabase).",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "desktop:dev": "pnpm --filter @rg/desktop dev",
    "desktop:build": "pnpm --filter @rg/desktop build",
    "backend:dev": "pnpm --filter @rg/backend dev",
    "admin:dev": "pnpm --filter @rg/admin dev",
    "db:generate": "pnpm --filter @rg/backend prisma:generate",
    "db:migrate": "pnpm --filter @rg/backend prisma:migrate",
    "gen:icons": "node scripts/gen-icons.mjs"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "rimraf": "^6.0.1",
    "prettier": "^3.3.3",
    "sharp": "^0.33.5",
    "png-to-ico": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
